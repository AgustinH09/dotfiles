tmux_error_handler display-menu          -T '#[align=centre]  Handling Session '         -x 'C' -y 'C'             -H "default"             -s "default"             -S "default"  "Back to Main menu <==" Left "run-shell '/home/chicha09/.tmux/plugins/tmux-menus/items/main.sh'" "" "Rename this session" r "command-prompt -I '#S'             'rename-session -- \"%%\"'" "New session" + "command-prompt -p             'Name of new session: '             'new-session -d -s \"%1\" ; switch-client -t \"%1\"'" "" "Last selected session" l "switch-client -l ; run-shell \"/home/chicha09/.tmux/plugins/tmux-menus/items/sessions.sh\"" "Previous session [in order]" p "switch-client -p ; run-shell \"/home/chicha09/.tmux/plugins/tmux-menus/items/sessions.sh\"" "Next     session [in order]" n "switch-client -n ; run-shell \"/home/chicha09/.tmux/plugins/tmux-menus/items/sessions.sh\"" "" "Kill current session" x "confirm-before -p         'Are you sure you want to kill this session? (y/n)'         'set -s detach-on-destroy no-detached ; kill-session'" "Kill all other sessions" o "confirm-before -p         'Are you sure you want to kill all other sessions? (y/n)'         'kill-session -a'"

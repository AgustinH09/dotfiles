case "$-" in
    *i*) ;;
      *) return;;
esac

# Vscode and Cursor Agent mode detection
if [[ -n "$npm_config_yes" ]] || [[ -n "$CI" ]] || [[ "$TERM_PROGRAM" == "vscode" ]]; then
  export AGENT_MODE=true
else
  export AGENT_MODE=false
fi

# ---- User Configuration ----
export PATH="$HOME/bin:$HOME/.local/bin:/usr/local/bin:$PATH"
export MANPATH="/usr/bin/man:$MANPATH"
export LANG=en_US.UTF-8

# Set default editor (nvim) or fallback to vim for SSH
if [[ -n "$SSH_CONNECTION" ]]; then
  export EDITOR='vim'
  export VISUAL='vim'
else
  export EDITOR='nvim'
  export VISUAL='nvim'
fi

# GPG
export GPG_TTY=$(tty)

# Hyprland Session Variables
export XDG_SESSION_DESKTOP=hyprland
export XDG_CURRENT_DESKTOP=hyprland
export XDG_SESSION_TYPE=wayland

# fcitx5 Input Method
export LC_CTYPE=en_US.UTF-8
export XMODIFIERS="@im=fcitx"
export QT_IM_MODULE=fcitx
export SDL_IM_MODULE=fcitx
export GLFW_IM_MODULE=ibus

# Bob - Neovim
export PATH="$HOME/.local/share/bob/nvim-bin:$PATH"

# Docker Host
export DOCKER_HOST="unix:///var/run/docker.sock"

# Golang
export GOPATH="$HOME/go"
export PATH="$PATH:/usr/local/go/bin:$GOPATH/bin"

# Android SDK
export ANDROID_HOME="$HOME/Android/Sdk"
export PATH="$PATH:$ANDROID_HOME/tools:$ANDROID_HOME/tools/bin:$ANDROID_HOME/platform-tools"

# ElasticBeanstalk
export PATH="/home/chicha09/.ebcli-virtual-env/executables:$PATH"

# Bat Theme
export BAT_THEME="tokyonight_moon"

# Cargo
[ -f "$HOME/.cargo/env" ] && source "$HOME/.cargo/env"

# API Keys (sourced from a separate file)
[ -f ~/.api_keys ] && source ~/.api_keys


# ---- Additional Tools ----

# Mise (Version Manager)
# Use agent-safe PATH export in Agent Mode, otherwise use standard activation.
if [[ "$AGENT_MODE" == "true" ]]; then
  export PATH="$HOME/.local/share/mise/shims:$PATH"
else
  eval "$(/home/chicha09/.local/bin/mise activate bash)"
fi

# Zoxide (Smart cd)
eval "$(zoxide init bash)"

# Terraform (Autocomplete)
complete -C /usr/bin/terraform terraform

# TheFuck (Command Corrector)
eval "$(thefuck --alias fk)"

if [ -x /usr/bin/dircolors ]; then
    test -r ~/.dircolors && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"
    alias ls='ls --color=auto'
    alias dir='dir --color=auto'
    alias vdir='vdir --color=auto'
    alias grep='grep --color=auto'
    alias fgrep='fgrep --color=auto'
    alias egrep='egrep --color=auto'
fi
